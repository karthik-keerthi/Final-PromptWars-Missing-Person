rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^/.*"));
    }
    
    function isValidMissingPerson(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.age is number && data.age >= 0 && data.age <= 150 &&
             isValidUrl(data.personImageWebLink) &&
             data.status in ['missing', 'found'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /missingPersons/{personId} {
      // Public access requested by user for hackathon prototype
      allow read: if true;
      
      allow create: if hasRequiredFields(['name', 'age', 'personImageWebLink', 'status', 'createdAt']) &&
                    isValidMissingPerson(request.resource.data);
                    
      allow update: if isValidMissingPerson(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if true;
    }
  }
}
